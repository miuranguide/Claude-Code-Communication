rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the request user is an admin
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if the user owns the document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ─── Users collection ───
    match /users/{uid} {
      // Users can read their own profile
      allow read: if isOwner(uid);
      // Admins can read/write all users
      allow read, write: if isAdmin();
    }

    // ─── Messages collection ───
    match /messages/{messageId} {
      // Any authenticated user can read messages
      allow read: if isAuth();
      // Only admins can create/update/delete messages
      allow write: if isAdmin();
    }

    // ─── Devices collection ───
    match /devices/{deviceId} {
      // Users can read/write their own devices
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      // Admins can read/write all devices
      allow read, write: if isAdmin();
    }

    // ─── Logs collection ───
    match /logs/{logId} {
      // Any authenticated user can write logs
      allow create: if isAuth();
      // Only admins can read logs
      allow read: if isAdmin();
    }
  }
}
